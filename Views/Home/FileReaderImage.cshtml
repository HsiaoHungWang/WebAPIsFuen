
@{
    ViewData["Title"] = "FileReaderImage";
}

<h1>FileReader 讀取圖片</h1>
<input id="file1" type="file" multiple accept="image/*" />
<div class="zone">
</div>
<input type="button" value="上傳" id="buttonUpload" />
@section Scripts {
    <script>
        const myFile = document.querySelector("#file1");
        const zone = document.querySelector(".zone");
        const btnUpload = document.querySelector('#buttonUpload');
        let uploadFiles = new Array();

        myFile.addEventListener("change", event => {
            uploadFiles = Array.from(event.target.files);


            // for (let i = 0, max = event.target.files.length; i < max; i++) {
            //     fileViewer(event.target.files[i]);
            // }
            uploadFiles.forEach(theFile => {
                fileViewer(theFile);
            })
        });

        const removeImg = event => {
          console.log(uploadFiles);
            // console.log(event.target);  //<img>
            // console.log(event.target.dataset.name);

            //移除陣列中的圖片
            uploadFiles = uploadFiles.filter(file => {
                return file.name != event.target.dataset.name;;
            })
           //  console.log(uploadFiles);

           //移除網頁上圖片
            //event.target.parentNode => <div>
           event.target.parentNode.removeChild(event.target);
            console.log(uploadFiles);
        }
        function fileViewer(theFile) {
            //透過FileReader物件中readAsDataURL()讀取theFile的圖
            const reader = new FileReader();
            reader.readAsDataURL(theFile);
            reader.addEventListener('load', event => {
                //會得到base64的圖
               // console.log(event.target.result);
               //data-*  //*是自己取名  dataset.*
                const imgHtml = `<img src="${event.target.result}" ondblclick="removeImg(event)" data-name="${theFile.name}" class="thumb" />`;
                //beforeend 結束標籤</div>的前面
                zone.insertAdjacentHTML('beforeend', imgHtml);
            })
         
        }

        zone.addEventListener("dragover", event => event.preventDefault());
        zone.addEventListener("drop", event=>{
            event.preventDefault();
            event.stopPropagation();

            uploadFiles = Array.from(event.dataTransfer.files);
            // for (let i = 0, max = event.dataTransfer.files.length; i < max; i++) {
            //     fileViewer(event.dataTransfer.files[i]);
            // }
            uploadFiles.forEach(theFile => {
                fileViewer(theFile);
            })
        })

        btnUpload.addEventListener('click', async () => {
           // console.log(myFile.files);
           //將FileList轉成陣列           
           // const ArrayFiles = Array.from(myFile.files);

           //將File物件塞進FormData
            const formData = new FormData();
            uploadFiles.forEach(theFile => {
                formData.append("files",theFile);
            })

            //檔案上傳
            const response = await fetch('@Url.Content("~/home/ImagesUpload")', {
                method: 'POST',
                body: formData //JSON、FormData               
            });
            const data = await response.text();
            alert(data);
        })
    </script>
}

@section Styles{
    <style>
        .zone {
            width: 600px;
            height: 100px;
            border: 1px solid green;
            overflow-y: auto;
        }

        .thumb {
            height: 80px;
            margin: 10px;
            box-shadow: 1px 2px 5px silver;
        }
    </style>
}