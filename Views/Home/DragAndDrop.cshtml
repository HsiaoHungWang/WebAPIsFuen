
@{
    ViewData["Title"] = "DragAndDrop";
}

<h1>DragAndDrop</h1>
<div id="zone1" class="zone">
    <div id="d1" class="item" draggable="true">Item1</div>
    <div id="d2" class="item" draggable="true">Item2</div>
    <div id="d3" class="item" draggable="true">Item3</div>
    <a id="a1" href="https://www.ispan.com.tw" class="item">iSpan</a>
    <img src="~/images/bunny.png" class="item" id="img1">
</div>
<div id="zone2" class="zone"></div>

@section Scripts {
    <script>
        const divs = document.querySelectorAll('.item');
        const zones = document.querySelectorAll('.zone');

        //將拖曳對象ID存進DataTransfer物件中
        const dragstartHandler = event => {
            event.dataTransfer.setData("text/plain",event.target.id);
        }

        //從DataTransfer物件中取出被拖曳對象的ID
        const dropHandler = event => {
            event.preventDefault();
            event.stopPropagation();
            const sId = event.dataTransfer.getData("text/plain");

            const sObj = document.querySelector(`#${sId}`);
            event.target.appendChild(sObj);

        }

        //每一個要被拖曳的元素，綁定Dragstart事件
        divs.forEach(item => {
            item.addEventListener('dragstart', dragstartHandler);
        })

        //每一個要能夠放下元素的區域，都要綁定Dragover及Drop事件
        zones.forEach(zone => {
            zone.addEventListener('dragover', event => event.preventDefault());
            zone.addEventListener('drop', dropHandler);
        })

     

        
     
    </script>
}

@section Styles{
    <style>
        .zone {
            width: 600px;
            height: 150px;
            margin: 10px;
            border: 1px solid green;
        }

        .item {
            width: 80px;
            height: 40px;
            float: left;
            background-color: gray;
            margin: 5px;
            text-align: center;
        }

        .over {
            border: 3px red dashed;
        }

        a{color:white}
        a:hover{
            color:white;
            text-decoration:none;
        }
    </style>
}